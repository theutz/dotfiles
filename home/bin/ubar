#!/usr/bin/env zsh

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -m|--mode)
            mode="$2"
            shift
            shift
            ;;
        -r|--update)
            osascript -e 'tell application id "tracesOf.Uebersicht" to refresh widget id "ubar-ubar-jsx"'
            shift
            ;;
        -*|--*)
            echo "error: $1 is not a valid flag"
            shift
            ;;
        *)
            positional+="$1"
            shift
            ;;
    esac
done

set -- "${positional[@]}"

# 
# Environment Variables
# {{{
if [[ ! -n $UBAR_MODE_FILE ]]; then 
    UBAR_MODE_FILE="${HOME}/.ubar/mode"

    if [[ ! -d $(dirname $UBAR_MODE_FILE) ]]; then
        mkdir -p $(dirname $UBAR_MODE_FILE);
    fi

    if [[ ! -f $UBAR_MODE_FILE ]]; then
        touch $UBAR_MODE_FILE
    fi
fi
#}}}

#
# Do the Stuff
#{{{
if [[ -n $mode ]]; then 
    echo $mode >! $UBAR_MODE_FILE
fi

#}}}

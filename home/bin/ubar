#!/usr/bin/env zsh

while [[ "$#" -gt 0 ]]; do
    case $1 in
        -t|--title) title="$2"; shift; shift;;
        -m|--message) message="$2"; shift; shift;;;
        -*|--*) echo "error: $1 is not a valid flag"; shift;;
        *) positional+="$1"; shift;;
    esac
done

set -- "${positional[@]}"

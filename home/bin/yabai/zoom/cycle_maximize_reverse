#!/usr/bin/env zsh

window_id="$1"
window="$(yabai -m query --windows --window $window_id)"

parent="$(echo $window | jq '.["zoom-parent"]')"
fullscreen="$(echo $window | jq '.["zoom-fullscreen"]')"
native="$(echo $window | jq '.["native-fullscreen"]')"

if [[ $native == 1 ]]; then
    echo 'xl -> l'
    yabai -m window --toggle native-fullscreen
    yabai -m window --toggle zoom-fullscreen
    exit 0
fi

if [[ $fullscreen == 1 ]]; then
    echo 'l -> m'
    yabai -m window --toggle zoom-fullscreen
    yabai -m window --toggle zoom-parent
    exit 0
fi

if [[ $parent == 1 ]]; then
    echo 'm -> s'
    yabai -m window --toggle zoom-parent
    exit 0
fi

#!/usr/bin/env zsh

current_window_id="$(yabai -m query --windows --window | jq '.id')"
current_space_index="$(yabai -m query --spaces --space | jq '.index')"

yabai -m space --create

last_space_index="$(yabai -m query --spaces | jq 'last | .index')"

yabai -m space $last_space_index --move $current_space_index
yabai -m window $current_window_index --space $current_space_index
yabai -m space --focus $current_space_index

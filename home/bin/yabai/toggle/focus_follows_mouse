#!/usr/bin/env zsh

title="Focus Follows Mouse"
current=$(yabai -m config focus_follows_mouse)
new_state=""

case $current in
    autofocus) new_state="autoraise" ;;
    autoraise) new_state="off" ;;
    disabled) new_state="autofocus" ;;
esac

noti -t $title -m "${current} -> ${new_state}"
yabai -m config focus_follows_mouse $new_state

# ========== #
# == SKHD == #
# ========== #

# --------------- #
# - Setup Modes - #
# --------------- #

:: default : echo "default" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""
:: windowmode @ : echo "window" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""
:: prevmode @ : echo "prev" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""
:: nextmode @ : echo "next" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""
:: insertmode @ : echo "insert" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""
:: deletemode @ : echo "delete" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""
:: spacemode @ : echo "space" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""
:: applaunch @ : echo "applaunch" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""

default < cmd - escape ; windowmode
windowmode < escape ; default
windowmode, nextmode < 0x21 ; prevmode
windowmode, prevmode < 0x1E ; nextmode
windowmode < d ; deletemode
windowmode < i ; insertmode
windowmode < s ; spacemode
windowmode < a ; applaunch
prevmode, nextmode, insertmode, deletemode, spacemode, applaunch < escape ; windowmode

# -----------
# - Display -
# -----------

# Focus

nextmode < d : yabai -m display --focus next; \
	 skhd -k escape
prevmode < d : yabai -m display --focus prev; \
	 skhd -k escape

# Move

nextmode < shift - d : yabai -m window --display next && \
	 yabai -m display --focus next; \
	 skhd -k escape
prevmode < shift - d : yabai -m window --display prev && \
	 yabai -m display --focus prev; \
	 skhd -k escape

# ----------
# - Spaces -
# ----------

# Focus

prevmode < s : yabai -m space --focus prev; \
	 skhd -k escape
nextmode < s : yabai -m space --focus next; \
	 skhd -k escape
spacemode < l : yabai -m space --focus next;
spacemode < h : yabai -m space --focus prev

# Move Space

prevmode < shift - s : yabai -m space --move prev; \
	 skhd -k escape
nextmode < shift - s : yabai -m space --move next; \
	 skhd -k escape

# Move Window

nextmode < shift - w : yabai -m window --space next && \
	 yabai -m space --focus next; \
	 skhd -k escape
prevmode < shift - w : yabai -m window --space prev && \
	 yabai -m space --focus prev; \
	 skhd -k escape
spacemode < shift - h : yabai -m window --space prev && \
	  yabai -m space --focus prev
spacemode < shift - l : yabai -m window --space next && \
	  yabai -m space --focus next

# Manage

insertmode < s : yabai -m space --create && \
	   yabai -m space --focus last; \
	   skhd -k escape
deletemode < s : i="$(yabai -m query --spaces --space | jq .index)"; \
	   yabai -m space --destroy && \
	   yabai -m space --focus $(expr $i - 1); \
	   skhd -k escape
spacemode < i : yabai -m space --create
spacemode < d : i="$(yabai -m query --spaces --space | jq .index)"; \
	  yabai -m space --destroy && \
	  yabai -m space --focus $(expr $i - 1) 

# -----------
# - Windows -
# -----------

# Focus

windowmode < h : yabai -m window --focus west
windowmode < j : yabai -m window --focus south
windowmode < k : yabai -m window --focus north
windowmode < l : yabai -m window --focus east

# Move

windowmode < shift - h : yabai -m window --swap west
windowmode < shift - j : yabai -m window --swap south
windowmode < shift - k : yabai -m window --swap north
windowmode < shift - l : yabai -m window --swap east

# Close

deletemode < d : yabai -m window --close; \
	   skhd -k escape

# Toggles

windowmode < z : yabai -m window --toggle zoom-parent
windowmode < shift - z : yabai -m window --toggle zoom-fullscreen
windowmode < v : yabai -m window --toggle split

# -------------- #
# - App Launch - #
# -------------- #

applaunch < t : /Applications/kitty.app/Contents/MacOS/kitty --single-instance -d ~; \
	   skhd -k escape; \
	   skhd -k escape
applaunch < e : emacsclient -c -a '' -n; \
	  skhd -k escape; \
	  skhd -k escape

# --------- #
# - Other - #
# --------- #

windowmode < shift - 8 : skhd -k escape && \
	   skhd --reload && \
	   noti -t 'skhd' -m 'Configuration Reloaded';
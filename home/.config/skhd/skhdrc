# ========== #
# == SKHD == #
# ========== #

# --------------- #
# - Setup Modes - #
# --------------- #

:: default : skhd-refresh-widget "default"
:: normal @ : skhd-refresh-widget "normal"
:: normalg @ : skhd-refresh-widget "normal (g)"
:: yank @ : skhd-refresh-widget "yank"
:: yankg @ : skhd-refresh-widget "yank (g)"
:: ex @ : skhd-refresh-widget "ex"

# ---------------

default < cmd - escape ; normal
normal < escape ; default

normal < g ; normalg
normalg < escape ; normal

normal < d ; yank
yank < escape ; normal

yank < g ; yankg
yankg < escape ; yank

normal < shift - 0x29 ; ex
ex < escape ; normal

# ----------- #
# - Hotkeys - #
# ----------- #

normal < tab : yabai -m space --balance
normal < h : yabai-cycle-window-focus-counterclockwise
normal < l : yabai-cycle-window-focus-clockwise
normal < j : yabai-cycle-window-focus-downwards
normal < k : yabai-cycle-window-focus-upwards
normal < ctrl - u : yabai-cycle-focus-to-prev-display
normal < ctrl - d : yabai-cycle-focus-to-next-display
normal < shift - h : yabai-cycle-focus-to-prev-space
normal < shift - l : yabai-cycle-focus-to-next-space
normal < shift - t : yabai-move-current-window-to-new-space
normal < c : yabai-destroy-current-space
normal < 1 : yabai -m space --focus 1
normal < 2 : yabai -m space --focus 2
normal < 3 : yabai -m space --focus 3
normal < 4 : yabai -m space --focus 4
normal < 5 : yabai -m space --focus 5
normal < 6 : yabai -m space --focus 6
normal < 7 : yabai -m space --focus 7
normal < 8 : yabai -m space --focus 8
normal < 9 : yabai -m space --focus 9

# ---------------

normalg < j : yabai-cycle-window-focus-by-index-desc; skhd-escape-mode
normalg < k : yabai-cycle-window-focus-by-index-asc; skhd-escape-mode
normalg < t : yabai-cycle-focus-to-prev-space; skhd-escape-mode
normalg < shift - t : yabai-cycle-focus-to-next-space; skhd-escape-mode

# ---------------

yank < 1 : yabai-move-current-window-to-space-by-index 1
yank < 2 : yabai-move-current-window-to-space-by-index 2
yank < 3 : yabai-move-current-window-to-space-by-index 3
yank < 4 : yabai-move-current-window-to-space-by-index 4
yank < 5 : yabai-move-current-window-to-space-by-index 5
yank < 6 : yabai-move-current-window-to-space-by-index 6
yank < 7 : yabai-move-current-window-to-space-by-index 7
yank < 8 : yabai-move-current-window-to-space-by-index 8
yank < 9 : yabai-move-current-window-to-space-by-index 9
yank < ctrl - d : yabai-move-current-window-to-next-display
yank < ctrl - u : yabai-move-current-window-to-prev-display
yank < shift - h : yabai-move-current-window-to-prev-space; skhd-escape-mode
yank < shift - l : yabai-move-current-window-to-next-space; skhd-escape-mode

# ---------------

yankg < t : yabai-move-current-window-to-next-space; skhd-escape-mode 2
yankg < shift - t : yabai-move-current-window-to-prev-space; skhd-escape-mode 2

# ---------------

ex < s : skhd-reload; skhd-escape-mode 2
ex < y : brew services restart yabai; skhd-escape-mode 2
ex < m : yabai-toggle-mouse-autofocus; skhd-escape-mode 2

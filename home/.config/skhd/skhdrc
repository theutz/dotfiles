# ========== #
# == SKHD == #
# ========== #

# --------------- #
# - Setup Modes - #
# --------------- #

:: default : skhd_refresh_widget "default"
:: normal @ : skhd_refresh_widget "normal"
:: normalg @ : skhd_refresh_widget "normal (g)"
:: yank @ : skhd_refresh_widget "yank"
:: yankg @ : skhd_refresh_widget "yank (g)"
:: ex @ : skhd_refresh_widget "ex"

# ---------------

default < cmd - escape ; normal
normal < escape ; default

normal < g ; normalg
normalg < escape ; normal

normal < d ; yank
yank < escape ; normal

yank < g ; yankg
yankg < escape ; yank

normal < shift - 0x29 ; ex
ex < escape ; normal

# ----------- #
# - Hotkeys - #
# ----------- #

normal < tab : yabai -m space --balance
normal < h : yabai_cycle_window_focus_counterclockwise
normal < l : yabai_cycle_window_focus_clockwise
normal < j : yabai_cycle_window_focus_downwards
normal < k : yabai_cycle_window_focus_upwards
normal < ctrl - u : yabai_cycle_focus_to_prev_display
normal < ctrl - d : yabai_cycle_focus_to_next_display
normal < shift - h : yabai_cycle_focus_to_prev_space
normal < shift - l : yabai_cycle_focus_to_next_space
normal < c : yabai_destroy_current_space
normal < 1 : yabai -m space --focus 1
normal < 2 : yabai -m space --focus 2
normal < 3 : yabai -m space --focus 3
normal < 4 : yabai -m space --focus 4
normal < 5 : yabai -m space --focus 5
normal < 6 : yabai -m space --focus 6
normal < 7 : yabai -m space --focus 7
normal < 8 : yabai -m space --focus 8
normal < 9 : yabai -m space --focus 9

# ---------------

normalg < j : yabai_cycle_window_focus_by_index_desc; skhd_escape_mode
normalg < k : yabai_cycle_window_focus_by_index_asc; skhd_escape_mode
normalg < t : yabai_cycle_focus_to_next_space; skhd_escape_mode
normalg < shift - t : yabai_cycle_focus_to_prev_space; skhd_escape_mode

# ---------------

yank < 1 : yabai_move_current_window_to_space_by_index 1; skhd_escape_mode
yank < 2 : yabai_move_current_window_to_space_by_index 2; skhd_escape_mode
yank < 3 : yabai_move_current_window_to_space_by_index 3; skhd_escape_mode
yank < 4 : yabai_move_current_window_to_space_by_index 4; skhd_escape_mode
yank < 5 : yabai_move_current_window_to_space_by_index 5; skhd_escape_mode
yank < 6 : yabai_move_current_window_to_space_by_index 6; skhd_escape_mode
yank < 7 : yabai_move_current_window_to_space_by_index 7; skhd_escape_mode
yank < 8 : yabai_move_current_window_to_space_by_index 8; skhd_escape_mode
yank < 9 : yabai_move_current_window_to_space_by_index 9; skhd_escape_mode
yank < shift - 1 : yabai_move_space 1; skhd_escape_mode
yank < shift - 2 : yabai_move_space 2; skhd_escape_mode
yank < shift - 3 : yabai_move_space 3; skhd_escape_mode
yank < shift - 4 : yabai_move_space 4; skhd_escape_mode
yank < shift - 5 : yabai_move_space 5; skhd_escape_mode
yank < shift - 6 : yabai_move_space 6; skhd_escape_mode
yank < shift - 7 : yabai_move_space 7; skhd_escape_mode
yank < shift - 8 : yabai_move_space 8; skhd_escape_mode
yank < shift - 9 : yabai_move_space 9; skhd_escape_mode
yank < ctrl - d : yabai_move_current_window_to_next_display; skhd_escape_mode
yank < ctrl - u : yabai_move_current_window_to_prev_display; skhd_escape_mode
yank < shift - h : yabai_move_current_window_to_prev_space; skhd_escape_mode
yank < shift - l : yabai_move_current_window_to_next_space; skhd_escape_mode
yank < shift - t : yabai_move_current_window_to_new_space; skhd_escape_mode

# ---------------

yankg < t : yabai_move_space next; skhd_escape_mode 2
yankg < shift - t : yabai_move_space prev; skhd_escape_mode 2

# ---------------

ex < s : skhd_reload; skhd_escape_mode 2
ex < y : brew services restart yabai; skhd_escape_mode 2
ex < m : yabai_toggle_mouse_autofocus; skhd_escape_mode 2

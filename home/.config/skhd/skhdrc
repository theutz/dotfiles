# =========== #
# == YABAI == #
# =========== #

# --------------- #
# - Setup Modes - #
# --------------- #

:: default : echo "default" > ~/.skhd_mode
:: normalmode @ : echo "normal" > ~/.skhd_mode
:: prevmode @ : echo "prev" > ~/.skhd_mode
:: nextmode @ : echo "next" > ~/.skhd_mode
:: insertmode @ : echo "insert" > ~/.skhd_mode 
:: deletemode @ : echo "delete" > ~/.skhd_mode
:: spacemode @ : echo "space" > ~/.skhd_mode

default < cmd - escape ; normalmode
normalmode < escape ; default
normalmode, nextmode < 0x21 ; prevmode
normalmode, prevmode < 0x1E ; nextmode
normalmode < d ; deletemode
normalmode < i ; insertmode
normalmode < s ; spacemode
prevmode, nextmode, insertmode, deletemode, spacemode < escape ; normalmode

# -----------
# - Display -
# -----------

# Focus

nextmode < d : yabai -m display --focus next; \
	 skhd -k escape
prevmode < d : yabai -m display --focus prev; \
	 skhd -k escape

# Move

nextmode < shift - d : yabai -m window --display next
prevmode < shift - d : yabai -m window --display prev

# ----------
# - Spaces -
# ----------

# Focus

prevmode < s : yabai -m space --focus prev; skhd -k escape
nextmode < s : yabai -m space --focus next; skhd -k escape
spacemode < l : yabai -m space --focus next;
spacemode < h : yabai -m space --focus prev

# Move

nextmode < shift - s : yabai -m window --space next && \
	 yabai -m space --focus next; \
	 skhd -k escape
prevmode < shift - s : yabai -m window --space prev && \
	 yabai -m space --focus prev; \
	 skhd -k escape
spacemode < shift - h : yabai -m window --space prev && \
	  yabai -m space --focus prev
spacemode < shift - l : yabai -m window --space next && \
	  yabai -m space --focus next

# Manage

insertmode < s : yabai -m space --create && \
	   yabai -m space --focus last; \
	   skhd -k escape
deletemode < s : i="$(yabai -m query --spaces --space | jq .index)"; \
	   yabai -m space --destroy && \
	   yabai -m space --focus $(expr $i - 1); \
	   skhd -k escape
spacemode < i : yabai -m space --create
spacemode < d : i="$(yabai -m query --spaces --space | jq .index)"; \
	  yabai -m space --destroy && \
	  yabai -m space --focus $(expr $i - 1) 

# -----------
# - Windows -
# -----------

# Focus

normalmode < h : yabai -m window --focus west
normalmode < j : yabai -m window --focus south
normalmode < k : yabai -m window --focus north
normalmode < l : yabai -m window --focus east

# Move

normalmode < shift - h : yabai -m window --swap west
normalmode < shift - j : yabai -m window --swap south
normalmode < shift - k : yabai -m window --swap north
normalmode < shift - l : yabai -m window --swap east

# Close
deletemode < w : yabai -m window --close

# Toggles

normalmode < z : yabai -m window --toggle zoom-parent
normalmode < shift - z : yabai -m window --toggle zoom-fullscreen
normalmode < v : yabai -m window --toggle split

# ---------
# - Other -
# ---------

normalmode < t : /Applications/kitty.app/Contents/MacOS/kitty --single-instance -d ~; \
	   skhd -k escape
normalmode < shift - 8 : skhd --reload && \
	   noti -t 'skhd' -m 'Configuration Reloaded'; \
	   skhd -k "cmd + alt + ctrl - i"
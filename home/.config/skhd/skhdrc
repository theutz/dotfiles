# ========== #
# == SKHD == #
# ========== #

# ---------------
# - Setup Modes -
# ---------------

:: default : echo "default" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""

:: windowmode @ : echo "window" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""

:: spacemode @ : echo "space" > ~/.skhd_mode && \
   osascript -e "tell application id \"tracesOf.Uebersicht\" to refresh widget id \"skhd-mode-skhd-mode-jsx\""

# To Window Mode
default < cmd - escape ; windowmode
spacemode < escape ; windowmode

# To Default Mode
windowmode < escape ; default

# To Space Mode
windowmode < cmd - escape ; spacemode


# ------------
# - Displays -
# ------------

# Focus Display

spacemode < h : yabai -m display --focus prev
spacemode < l : yabai -m display --focus next

# Move Window to Display

spacemode < shift - h : yabai -m window --display prev
spacemode < shift - l : yabai -m window --display next

# ----------
# - Spaces -
# ----------

# Focus

spacemode < j : yabai -m space --focus prev
spacemode < k : yabai -m space --focus next

# Move Space

spacemode < alt - j : yabai -m space --move prev
spacemode < alt - k : yabai -m space --move next

# Move Window to Space

spacemode < shift - j : yabai -m window --space prev
spacemode < shift - k : yabai -m window --space next

# Create

spacemode < i : yabai -m space --create

# Destroy

spacemode < x : yabai -m space --destroy

# -----------
# - Windows -
# -----------

# Focus

windowmode < h : yabai -m window --focus west
windowmode < j : yabai -m window --focus south
windowmode < k : yabai -m window --focus north
windowmode < l : yabai -m window --focus east

# Move

windowmode < shift - h : yabai -m window --swap west
windowmode < shift - j : yabai -m window --swap south
windowmode < shift - k : yabai -m window --swap north
windowmode < shift - l : yabai -m window --swap east

# Close

windowmode < d : yabai -m window --close

# Toggles

windowmode < z : yabai -m window --toggle zoom-parent
windowmode < shift - z : yabai -m window --toggle zoom-fullscreen
windowmode < v : yabai -m window --toggle split

# --------- #
# - Other - #
# --------- #

windowmode < shift - 8 : skhd --reload && \
	   noti -t 'skhd' -m 'Configuration Reloaded';

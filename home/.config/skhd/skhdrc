#
# Spaces
#

# Move
cmd + alt + ctrl - p : yabai -m space --focus next || yabai -m space --focus first
cmd + alt + ctrl - n : yabai -m space --focus prev || yabai -m space --focus last
cmd + alt + shift - n : yabai -m window --space next && yabai -m space --focus next
cmd + alt + shift - p : yabai -m window --space prev && yabai -m space --focus prev
cmd + alt + ctrl - 0x18 : yabai -m space --create
cmd + alt + ctrl - 0x1B : yabai -m space --destroy

#
# Windows
#

# Focus
cmd + alt + ctrl - h : yabai -m window --focus west
cmd + alt + ctrl - j : yabai -m window --focus south
cmd + alt + ctrl - k : yabai -m window --focus north
cmd + alt + ctrl - l : yabai -m window --focus east

# Swap
cmd + alt + shift - h : yabai -m window --swap west
cmd + alt + shift - j : yabai -m window --swap south
cmd + alt + shift - k : yabai -m window --swap north
cmd + alt + shift - l : yabai -m window --swap east

# Float
cmd + alt + ctrl - return : yabai -m window --toggle zoom-parent
cmd + alt + ctrl - space : yabai -m window --toggle zoom-fullscreen

# Split
cmd + alt + ctrl - 0x2F : yabai -m window --toggle split

#
# Other
#
ctrl + alt - return : /Applications/kitty.app/Contents/MacOS/kitty --single-instance -d ~
cmd + alt + ctrl - r : skhd --reload && noti -t 'skhd' -m 'Reload config!'
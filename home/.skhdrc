#
# Default Mode
#{{{
:: default : ubar --update --mode "Default"

ctrl + alt + cmd - y : launchctl kickstart -k "gui/${UID}/homebrew.mxcl.yabai"
ctrl + alt + cmd - u : osascript -e 'tell application id "tracesOf.Uebersicht" to refresh'
cmd - tab : echo "Command + Tab has been suspended"
cmd + shift - tab : echo "Command + Tab has been suspended"
# }}}

#
# Yabai Mode
# {{{
:: yabai @ : ubar --update --mode "Yabai"
default < cmd - escape ; yabai
yabai < escape ; default

yabai < h : yabai -m space --focus prev
yabai < j : yabai -m window --focus next
yabai < k : yabai -m window --focus prev
yabai < l : yabai -m space --focus next

yabai < 0 : yabai -m space --focus first
yabai < shift - 4 : source ~/bin/yabai/default/goto_last_space

yabai < shift - i : source ~/bin/yabai/default/move_to_new_first_space
yabai < a : source ~/bin/yabai/default/move_to_new_next_space
yabai < i : source ~/bin/yabai/default/move_to_new_prev_space
yabai < shift - a : yabai -m space --create; yabai -m window --space last

yabai < m : source ~/bin/yabai/default/cycle_maximize
yabai < shift - m : source ~/bin/yabai/default/cycle_maximize_reverse

yabai < r : yabai -m space --rotate 90
yabai < shift - r : yabai -m space --rotate 270
yabai < y : CURRENT_WINDOW_ID="$(yabai -m query --windows --window | jq '.id')"; \
      echo $CURRENT_WINDOW_ID | pbcopy; \
      noti -t "Window ID Copied" -m "$CURRENT_WINDOW_ID";
yabai < b : yabai -m space --balance

yabai < shift - h : yabai -m window --space prev
yabai < shift - j : yabai -m window --swap next
yabai < shift - k : yabai -m window --swap prev
yabai < shift - l : yabai -m window --space next

yabai < p : CURRENT_SPACE="$(yabai -m query --spaces --space | jq '.index')"; \
      WINDOW_ID="$(pbpaste)"; \
      yabai -m window $WINDOW_ID --space $CURRENT_SPACE

yabai < ctrl - d : yabai -m space --move next
yabai < ctrl - u : yabai -m space --move prev

yabai < 0x1B : yabai -m window --ratio rel:0.1
yabai < 0x18 : yabai -m window --ratio rel:-0.1
#}}}

#
# Yabai > Toggle Mode
#{{{
:: t_ @ : ubar --update --mode "Yabai > Toggle"
yabai < t ; t_
t_ < escape ; yabai

t_ < m : source ~/bin/yabai/toggle/focus_follows_mouse; \
   skhd -k escape
t_ < f : yabai -m window --toggle float; \
   skhd -k escape
t_ < s : yabai -m window --toggle sticky; \
   skhd -k escape
t_ < b : yabai -m window --toggle border; \
   skhd -k escape
t_ < x : yabai -m space --mirror x-axis; \
   skhd -k escape
t_ < y : yabai -m space --mirror y-axis; \
   skhd -k escape
t_ < v : yabai -m window --toggle split; \
   skhd -k escape
#}}}

#
# Yabai > Goto Mode
#{{{
:: g_ @ : ubar --update --mode "Yabai > Goto"
yabai < g ; g_
g_ < escape ; yabai

g_ < t : yabai -m window --display next; skhd -k escape
g_ < shift - t : yabai -m window --display prev; skhd -k escape
#}}}

#
# Yabai > Window Mode
#
:: cw_ @ : ubar --update --mode "Yabai > Window"
yabai < ctrl - w; cw_
cw_ < escape ; yabai

cw_ < h : yabai -m display --focus prev; skhd -k escape
cw_ < l : yabai -m display --focus next; skhd -k escape
cw_ < shift - h : yabai -m window --display prev; skhd -k escape
cw_ < shift - l : yabai -m window --display next; skhd -k escape
cw_ < ctrl - w : (yabai -m space --display next || yabai -m space --display prev); skhd -k escape
#

#
# Yabai > Prev Mode
# {{{
:: prev_ @ : ubar --update --mode "Yabai > Prev"
yabai < 0x21 ; prev_
prev_ < escape ; yabai

prev_ < w : ( \
                yabai -m window --swap prev || \
                yabai -m window --swap last \
            ); \
            skhd -k escape
prev_ < s : ( \
                ( \
                    yabai -m window --space prev && \
                    yabai -m space --focus prev \
                ) || \
                ( \
                    yabai -m space --create && \
                    yabai -m window --space last && \
                    yabai -m space --focus last \
                ) \
            ); \
            skhd -k escape
#}}}

#
# Yabai > Next Mode
#{{{
:: next_ @ : ubar --update --mode "Yabai > Next"
yabai < 0x1E ; next_
next_ < escape ; yabai

next_ < w : ( \
                yabai -m window --swap next || \
                yabai -m window --swap first \
            ); \
            skhd -k escape
next_ < s : ( \
                ( \
                    yabai -m window --space next && \
                    yabai -m space --focus next \
                ) || \
                ( \
                    yabai -m space --create && \
                    yabai -m window --space last && \
                    yabai -m space --focus last \
                ) \
            );  \
            skhd -k escape
#}}}

#
# Yabai > Delete Mode
#{{{
:: d_ @ : ubar --update --mode "Yabai > Delete"
yabai < d ; d_
d_ < escape ; yabai

d_ < s : source ~/bin/yabai/delete/space; \
   skhd -k escape
d_ < w : source ~/bin/yabai/delete/window; \
   skhd -k escape
#}}}

# vim: fdm=marker fdl=0

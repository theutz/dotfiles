#         SKHD_CURRENT_SPACE="$(yabai -m query --spaces --space | jq .index)"; \
#         yabai -m space --destroy && \
#         yabai -m space --focus $SKHD_CURRENT_SPACE; \
#         skhd -k escape
#}}}


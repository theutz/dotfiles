#
# Default Mode
#{{{
:: default : ubar --update --mode "Default"

cmd - tab -> : noti -t "Ah ah ah..." -m "CMD + Tab? Don't do it!"
ctrl + alt + cmd - r : launchctl kickstart -k "gui/${UID}/homebrew.mxcl.yabai"
#}}}

#
# Yabai Mode
# {{{
:: yabai @ : ubar --update --mode "Yabai"
default < cmd - escape ; yabai
yabai < escape ; default

yabai < h : yabai -m space --focus prev; yabai -m window --focus mouse
yabai < j : yabai -m window --focus next
yabai < k : yabai -m window --focus prev
yabai < l : yabai -m space --focus next; yabai -m window --focus mouse
yabai < 0 : yabai -m space --focus first; yabai -m window --focus mouse
yabai < shift - 4 : yabai -m space --focus last; yabai -m window --focus mouse

yabai < p : source ~/bin/yabai/default/paste_new_space
yabai < shift - A : yabai -m space --create; yabai -m window --space last

yabai < return : yabai -m window --toggle zoom-fullscreen
yabai < space : yabai -m window --toggle zoom-parent
#}}}

#
# Yabai > Toggle Mode
#
:: t_ @ : ubar --update --mode "Yabai > Toggle"
yabai < t ; t_
t_ < escape ; yabai

t_ < f : source ~/bin/yabai/toggle/focus_follows_mouse

#
# Yabai > Goto Mode
#{{{
:: g_ @ : ubar --update --mode "Yabai > Goto"
yabai < g ; g_
g_ < escape ; yabai

g_ < j : \
        yabai -m window --focus south || \
        skhd -k 'escape'; \
        skhd -k 'j'
g_ < k : \
        yabai -m window --focus north || \
        skhd -k 'escape'; \
        skhd -k 'k'
#}}}

#
# Yabai > Prev Mode
# {{{
:: prev_ @ : ubar --update --mode "Yabai > Prev"
yabai < 0x21 ; prev_
prev_ < escape ; yabai

prev_ < w : ( \
                yabai -m window --swap prev || \
                yabai -m window --swap last \
            ); \
            skhd -k escape
prev_ < s : ( \
                ( \
                    yabai -m window --space prev && \
                    yabai -m space --focus prev \
                ) || \
                ( \
                    yabai -m space --create && \
                    yabai -m window --space last && \
                    yabai -m space --focus last \
                ) \
            ); \
            skhd -k escape
#}}}

#
# Yabai > Next Mode
#{{{
:: next_ @ : ubar --update --mode "Yabai > Next"
yabai < 0x1E ; next_
next_ < escape ; yabai

next_ < w : ( \
                yabai -m window --swap next || \
                yabai -m window --swap first \
            ); \
            skhd -k escape
next_ < s : ( \
                ( \
                    yabai -m window --space next && \
                    yabai -m space --focus next \
                ) || \
                ( \
                    yabai -m space --create && \
                    yabai -m window --space last && \
                    yabai -m space --focus last \
                ) \
            );  \
            skhd -k escape
#}}}

#
# Yabai > Delete Mode
#{{{
:: d_ @ : ubar --update --mode "Yabai > Delete"
yabai < d ; d_
d_ < escape ; yabai

d_ < s : source ~/bin/yabai/delete/space

#!/usr/bin/env zsh

window_id="$1"
zoom_level="$(source ~/bin/yabai/util/get_window_zoom $window_id)"

case $zoom_level in
    native)
        yabai -m window --toggle native-fullscreen
        yabai -m window --toggle zoom-fullscreen
        ;;
    fullscreen)
        yabai -m window --toggle zoom-fullscreen
        if [[ "$(yabai -m query --windows --window | jq '.["zoom-parent"]')" -ne 0 ]]; then
            yabai -m window --toggle zoom-parent
        fi
        ;;
    parent)
        yabai -m window --toggle zoom-parent
        ;;
    none)
        noti -t "Yabai" -m "Minimum zoom reached"
        ;;
    *)
        echo "Zoom level not found" >&2
        exit 1
esac


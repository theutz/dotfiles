#!/usr/bin/env zsh

window_id="$1"
zoom_level="$(source ~/bin/yabai/util/get_window_zoom $window_id)"

echo "$zoom_level"

case $zoom_level in
    native)
        noti -t "Yabai" -m "Highest zoom level"
        ;;
    fullscreen)
        yabai -m window --toggle zoom-fullscreen
        yabai -m window --toggle native-fullscreen
        ;;
    parent)
        yabai -m window --toggle zoom-parent
        yabai -m window --toggle zoom-fullscreen
        ;;
    none)
        yabai -m window --toggle zoom-parent
        ;;
    *)
esac

#!/usr/bin/env zsh

window_id=$1
window="$(yabai -m query --windows --window $window_id)"

parent="$(echo $window | jq '.["zoom-parent"]')"
fullscreen="$(echo $window | jq '.["zoom-fullscreen"]')"
native="$(echo $window | jq '.["native-fullscreen"]')"


if [[ $parent == 1 ]]; then
    yabai -m window $window_id --toggle zoom-parent
fi

if [[ $fullscreen == 1 ]]; then
    yabai -m window $window_id --toggle zoom-fullscreen
fi

if [[ $native == 1 ]]; then
    yabai -m window $window_id --toggle native-fullscreen
fi

#!/usr/bin/env zsh

current_window="$(yabai -m query --windows --window | jq .id)"
target_space="$((`yabai -m query --spaces --space | jq .index` + 1 ))"

yabai -m space --create

last_space="$(yabai -m query --spaces | jq 'last | .index')"

yabai -m space $last_space --move $target_space
yabai -m window $current_window --space $target_space
yabai -m space --focus $target_space

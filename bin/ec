#!/usr/local/bin/zsh

query=$1

server="/usr/local/bin/brew services restart emacs-plus@28"
client="/usr/local/bin/emacsclient --alternate-editor='' --create-frame --no-wait"

if [[ $query != "server" ]]; then
  if eval $client; then
    echo "Launching emacsclient..."
  else
    if eval $server; then
      echo "Launching emacsclient..."
      eval $client;
	else
	  echo "Attempted to start emacs server..."
    fi
  fi
fi

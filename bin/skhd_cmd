#!/usr/bin/env zsh
setopt -euo pipefail

outfile="${HOME}/.config/ubersicht/yabai-skhd.widget/cmd.txt"

function usage() {
  cat << EOF
Utility for running SKHD commands that will work with Yabai & Ubersicht.

USAGE:
  skhd_cmd [options] description...

OPTIONS:
  -e, --escape
    Trigger an escape keypress

  -g, --get
    Echo the current contents of the command file.

  -h, --help
    Show this help

VARIABLES:
  outfile: ${outfile}
EOF
}

function do_get() {
  cat $outfile
  exit 0
}

if [[ $# == 0 ]]; then
  echo >&2 "Please provide a description."
  exit 1
fi

positional=()

while [[ $# -gt 0 ]]; do
  case $1 in 
    -e|--escape)
      do_escape=1
      shift
      ;;
    -g|--get)
      do_get
      ;;
    -h|--help)
      usage
      exit 1
      ;;
    *)
      positional+=$1
      shift
  esac
done

set -- "${positional[@]}"

if [[ ! -f $outfile ]]; then
  touch $outfile
fi

echo $@ >! $outfile

if ((${+do_escape})); then
  skhd -k escape
fi


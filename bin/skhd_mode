#!/usr/bin/env zsh

mode_file="${HOME}/.config/ubersicht/yabai-skhd.widget/mode.txt"

function echo_mode() {
  cat $mode_file
}

if [[ ! -f $mode_file ]]; then
  touch $mode_file
fi

if [[ $# == 0 ]]; then
  echo_mode
fi

while [[ $# -gt 0 ]]; do
  case $1 in
    --get)
      echo_mode
      shift
      ;;
    --set)
      echo "${2}" >! $mode_file
      shift
      shift
      ;;
    *)
      echo "Unrecognized argument: ${1}"
      exit 1
  esac
done

osascript -e 'tell application id "tracesOf.Uebersicht" to refresh widget id "yabai-skhd-widget-main-jsx"' 2>&1 > /dev/null
